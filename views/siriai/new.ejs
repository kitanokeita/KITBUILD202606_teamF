<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <title>
    <%= title %>
  </title>
</head>

<body class="form-page">
  <div class="form-container">
    <h1><%= title %></h1>

    <% if (errorMessage) { %>
      <div class="error-message"><%= errorMessage %></div>
    <% } %>

    <form action="/siriai/new" method="post">
      <div class="form-group">
        <label for="name">名前</label>
        <input type="text" id="name" name="name" value="<%= name %>" placeholder="近大太郎">
      </div>
      <div class="form-group">
        <label for="age">年齢</label>
        <input type="number" id="age" name="age" value="<%= age %>" placeholder="20">
      </div>
      <div class="form-group">
        <label for="relation">関係</label>
        <input type="text" id="relation" name="relation" value="<%= relation %>" placeholder="友達">
      </div>
      <div class="form-group">
        <label for="hobby">趣味</label>
        <input type="text" id="hobby" name="hobby" value="<%= hobby %>" placeholder="サッカー">
      </div>
      <div class="form-group">
        <label for="MBTI">性格 (MBTI)</label>
        <select id="MBTI" name="MBTI">
          <option value="" <%= MBTI === '' ? 'selected' : '' %>>選択してください</option>
          <option value="INTJ" <%= MBTI === 'INTJ' ? 'selected' : '' %>>INTJ</option>
          <option value="INTP" <%= MBTI === 'INTP' ? 'selected' : '' %>>INTP</option>
          <option value="ENTJ" <%= MBTI === 'ENTJ' ? 'selected' : '' %>>ENTJ</option>
          <option value="ENTP" <%= MBTI === 'ENTP' ? 'selected' : '' %>>ENTP</option>
          <option value="INFJ" <%= MBTI === 'INFJ' ? 'selected' : '' %>>INFJ</option>
          <option value="INFP" <%= MBTI === 'INFP' ? 'selected' : '' %>>INFP</option>
          <option value="ENFJ" <%= MBTI === 'ENFJ' ? 'selected' : '' %>>ENFJ</option>
          <option value="ENFP" <%= MBTI === 'ENFP' ? 'selected' : '' %>>ENFP</option>
          <option value="ISTJ" <%= MBTI === 'ISTJ' ? 'selected' : '' %>>ISTJ</option>
          <option value="ISFJ" <%= MBTI === 'ISFJ' ? 'selected' : '' %>>ISFJ</option>
          <option value="ESTJ" <%= MBTI === 'ESTJ' ? 'selected' : '' %>>ESTJ</option>
          <option value="ESFJ" <%= MBTI === 'ESFJ' ? 'selected' : '' %>>ESFJ</option>
          <option value="ISTP" <%= MBTI === 'ISTP' ? 'selected' : '' %>>ISTP</option>
          <option value="ISFP" <%= MBTI === 'ISFP' ? 'selected' : '' %>>ISFP</option>
          <option value="ESTP" <%= MBTI === 'ESTP' ? 'selected' : '' %>>ESTP</option>
          <option value="ESFP" <%= MBTI === 'ESFP' ? 'selected' : '' %>>ESFP</option>
        </select>
        <a class="link-small" href="https://shindan.vercel.app/posts/hXdsqlvSWmnSZORICCqP">わからない人はこのリンクをクリック</a>
      </div>
      <button type="submit" class="btn-primary" id="next-button">Mii作成する</button>
    </form>
    <a href="../" class="back-link-text">← 戻る</a>
  </div>
</body>

</html>
