<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/avatar.css">
    <link rel="stylesheet" href="/stylesheets/mii.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <h1>
        <%= name %>さんの<%= title %>
    </h1>

    <form action="/siriai/mii" method="post">
        <input type="hidden" name="name" value="<%= name %>">
        <input type="hidden" name="age" value="<%= age %>">
        <input type="hidden" name="relation" value="<%= relation %>">
        <input type="hidden" name="hobby" value="<%= hobby %>">
        <input type="hidden" name="MBTI" value="<%= MBTI %>">

        <div class="mii-layout">
            <div class="mii-left">
                <div class="showButton">
                    <input id="hair-button" type="button" value="髪型">
                    <input id="eyes-button" type="button" value="目">
                    <input id="mouth-button" type="button" value="口">
                </div>
                <%- include('parts')%>
            </div>

            <div class="mii-right">
                <%- include('avatar', {
                    boxSize: 'size-mii',
                    imgIdPrefix: 'preview',
                    hair: 1,
                    eyes: 1,
                    mouth: 1
                    })
                %>
                <div class="mii-actions">
                    <button type="submit">Mii完成</button>
                    <button type="submit" formaction="/siriai/ai">AIでアバターを作る</button>
                </div>
            </div>
        </div>
    </form>

    <script>
        function showParts(part) {
            document.getElementById('partsHair').style.display = 'none';
            document.getElementById('partsEyes').style.display = 'none';
            document.getElementById('partsMouth').style.display = 'none';
            document.getElementById(part).style.display = 'flex';
        }

        document.getElementById('hair-button').addEventListener('click', function () {
            showParts('partsHair');
        });
        document.getElementById('eyes-button').addEventListener('click', function () {
            showParts('partsEyes');
        });
        document.getElementById('mouth-button').addEventListener('click', function () {
            showParts('partsMouth');
        });

        document.querySelectorAll('input[name="hair"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                const img = document.getElementById('previewHair');
                img.src = '/img/hair' + this.value + '.png';
                img.style.display = 'block';
            });
        });
        document.querySelectorAll('input[name="eyes"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                const img = document.getElementById('previewEyes');
                img.src = '/img/eyes' + this.value + '.png';
                img.style.display = 'block';
            });
        });
        document.querySelectorAll('input[name="mouth"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                const img = document.getElementById('previewMouth');
                img.src = '/img/mouth' + this.value + '.png';
                img.style.display = 'block';
            });
        });
    </script>
</body>

</html>
