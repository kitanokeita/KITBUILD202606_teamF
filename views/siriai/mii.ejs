<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/avatar.css">
    <link rel="stylesheet" href="/stylesheets/mii.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <% 
        let currentHair = typeof hair !== 'undefined' ? hair : 1;
        let currentEyes = typeof eyes !== 'undefined' ? eyes : 1;
        let currentMouth = typeof mouth !== 'undefined' ? mouth : 1;
    %>

    <h1>
        <%= name %>さんの<%= title %>
    </h1>

    <form action="/siriai/mii" method="post">
        <input type="hidden" name="name" value="<%= name %>">
        <input type="hidden" name="age" value="<%= age %>">
        <input type="hidden" name="relation" value="<%= relation %>">
        <input type="hidden" name="hobby" value="<%= hobby %>">
        <input type="hidden" name="MBTI" value="<%= MBTI %>">

        <div class="mii-layout">
            <div class="mii-left">
                <div class="showButton">
                    <input id="hair-button" type="button" value="髪型">
                    <input id="eyes-button" type="button" value="目">
                    <input id="mouth-button" type="button" value="口">
                </div>
                <%- include('parts', { hair: currentHair, eyes: currentEyes, mouth: currentMouth })%>
            </div>

            <div class="mii-right">
                <%- include('avatar', {
                    boxSize: 'size-mii',
                    imgIdPrefix: 'preview',
                    hair: currentHair,
                    eyes: currentEyes,
                    mouth: currentMouth
                    })
                %>
                <div class="mii-actions">
                    <button type="submit">Mii完成</button>
                    <button type="submit" formaction="/siriai/ai">AIでアバターを作る</button>
                </div>
            </div>
        </div>
    </form>

    <script>
        function showParts(part) {
            document.getElementById('partsHair').style.display = 'none';
            document.getElementById('partsEyes').style.display = 'none';
            document.getElementById('partsMouth').style.display = 'none';
            document.getElementById(part).style.display = 'flex';
        }

        document.getElementById('hair-button').addEventListener('click', function () {
            showParts('partsHair');
        });
        document.getElementById('eyes-button').addEventListener('click', function () {
            showParts('partsEyes');
        });
        document.getElementById('mouth-button').addEventListener('click', function () {
            showParts('partsMouth');
        });

        // 画像のsrcを更新する共通関数
        function updatePreview(partName, value) {
            const imgId = 'preview' + partName.charAt(0).toUpperCase() + partName.slice(1);
            const img = document.getElementById(imgId);
            if (img) {
                img.src = '/img/' + partName + value + '.png';
                img.style.display = 'block';
            }
        }

        document.querySelectorAll('input[name="hair"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                updatePreview('hair', this.value);
            });
        });
        document.querySelectorAll('input[name="eyes"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                updatePreview('eyes', this.value);
            });
        });
        document.querySelectorAll('input[name="mouth"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                updatePreview('mouth', this.value);
            });
        });

        // ページが表示された時（戻るボタンでのキャッシュ復帰時も含む）に実行
        window.addEventListener('pageshow', function(event) {
            const parts = [
                { name: 'hair', serverVal: '<%= currentHair %>' },
                { name: 'eyes', serverVal: '<%= currentEyes %>' },
                { name: 'mouth', serverVal: '<%= currentMouth %>' }
            ];

            parts.forEach(function(part) {
                let targetValue;

                // event.persisted が true の場合は、ブラウザの「戻る」ボタンなどで復帰した時
                if (event.persisted) {
                    const checkedRadio = document.querySelector('input[name="' + part.name + '"]:checked');
                    targetValue = checkedRadio ? checkedRadio.value : part.serverVal;
                } else {
                    // AI解析直後など、通常の読み込み時は必ずサーバーから渡されたAIの推測値を使う
                    targetValue = part.serverVal;
                }

                // 対象のラジオボタンを選択状態にして画像を更新する
                const radioToSelect = document.querySelector('input[name="' + part.name + '"][value="' + targetValue + '"]');
                if (radioToSelect) {
                    radioToSelect.checked = true;
                    updatePreview(part.name, targetValue);
                }
            });
        });
    </script>
</body>

</html>